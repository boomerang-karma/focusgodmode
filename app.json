{
  "expo": {
    "name": "Avadhan Vidya",
    "slug": "avadhan-vidya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "avadhan-vidya",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0f0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ashwadhanam.avadhanvidya",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a0f0a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.ashwadhanam.avadhanvidya"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#c45c26"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow Avadhan Vidya to record compositions for Ashu-kavitva practice."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
